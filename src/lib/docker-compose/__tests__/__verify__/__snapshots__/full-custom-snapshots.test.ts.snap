exports[`Full Custom Profiles - Complete File Verification with YAML Parsing > should keep the database contract free of postgres services, env vars, and named volumes > full-custom-no-postgres-artifacts-zh-CN 1`] = `
"# Hagicode Docker Compose Configuration
# Auto-generated by Docker Compose Generator
# Generated at: 2024/1/1 00:00:00

# ==================================================
# 支持信息
# ==================================================
# 如果您遇到任何问题或需要技术支持:
# - 加入我们的 QQ 群: 610394020
# - 加入我们的 Discord 社区: https://discord.gg/qY662sJK
# - 我们提供实时协助和解决方案
# - 分享您的经验并与其他用户交流

services:
  hagicode:
    image: newbe36524/hagicode:0
    container_name: hagicode
    environment:
      ASPNETCORE_ENVIRONMENT: Production
      ASPNETCORE_URLS: http://+:45000
      TZ: Asia/Shanghai
      Database__Provider: sqlite
      ConnectionStrings__Default: "Data Source=/app/data/hagicode.db"
      License__Activation__LicenseKey: "public-license-key"
      # ==================================================
      # Codex Runtime Configuration
      # Uses CODEX_* environment variables
      # OPENAI_* variables are accepted as compatibility aliases
      # ==================================================
      CODEX_API_KEY: "test-codex-key"
      # Compatibility alias: OPENAI_API_KEY = CODEX_API_KEY
      # CODEX_BASE_URL: optional, uses default if not set
      # Compatibility alias: OPENAI_BASE_URL = CODEX_BASE_URL
      # ==================================================
      # Claude Runtime Configuration
      # All providers use ANTHROPIC_AUTH_TOKEN
      # ANTHROPIC_URL is set for ZAI, Aliyun, and custom providers
      # ==================================================
      # Anthropic Official API
      ANTHROPIC_AUTH_TOKEN: "test-token"
      # No ANTHROPIC_URL needed - uses default Anthropic endpoint
      # ==================================================
      # Code Server 部署默认值
      # ==================================================
      # 默认不公开宿主机端口；只有开启宿主机发布后才会导出独立映射
      # 系统级资源继续保存在 hagicode_data:/app/data；save-scoped 运行时状态会持久化到 hagicode_saves:/app/saves/save0/...
      VsCodeServer__DefaultActiveImplementation: "code-server"
      VsCodeServer__CodeServerDefaultHost: "127.0.0.1"
      VsCodeServer__CodeServerDefaultPort: 36529
      VsCodeServer__CodeServerExecutablePath: "code-server"
      VsCodeServer__CodeServerAuthMode: "none"
    ports:
      - "8080:45000"
    volumes:
      - /home/user/repos:/app/workdir
      # 系统级数据卷；Code Server 运行时状态会落在 /app/data/code-server
      - hagicode_data:/app/data
      # 存档级数据卷；主数据库与 Orleans 等状态会落在 /app/saves/save0/...
      - hagicode_saves:/app/saves
      - claude-data:/home/hagicode/.claude
      - codex-data:/home/hagicode/.codex
    networks:
      - pcode-network
    restart: unless-stopped

volumes:
  hagicode_data:
  hagicode_saves:
  claude-data:
  codex-data:

networks:
  pcode-network:
    driver: bridge"
`;
